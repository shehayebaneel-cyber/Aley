# Copy to .env and fill in. Never commit the real .env.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
PORT=4100
JWT_SECRET="change-me-to-a-long-random-string"
ADMIN_EMAIL="admin@aley.com"
ADMIN_PASSWORD="change-me"
ADMIN_NAME="Aley Admin"

# Payments (donations). Default is mock = no real charge.
# Set PAYMENT_PROVIDER=gateway and fill these once you have a merchant account.
PAYMENT_PROVIDER="mock"
PAYMENT_BASE_URL=""
PAYMENT_MERCHANT_ID=""
PAYMENT_API_KEY=""

# Admin email alerts (new business submitted, ownership claims).
# Leave SMTP_* blank → emails are just logged to the console (in-app admin
# notifications always work regardless). Fill these to send real email.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Aley Platform <no-reply@aley.com>"
PUBLIC_BASE_URL="http://localhost:5174"
