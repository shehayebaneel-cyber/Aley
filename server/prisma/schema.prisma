// Aley Platform — database schema.
//
// Multi-city by design: every Business, Event and Offer belongs to a City, so
// the same codebase serves Aley today and Beirut/Byblos/Batroun/Zahle/Sidon
// later with no rebuild. SQLite for local dev (statuses are strings, list/object
// columns are JSON-encoded strings); switch `provider` to postgresql to scale.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A city the platform serves. `isActive` gates it on the public site.
model City {
  id        Int        @id @default(autoincrement())
  slug      String     @unique // "aley", "beirut", ...
  name      String
  nameAr    String     @default("")
  tagline   String     @default("")
  lat       Float      @default(33.8056)
  lng       Float      @default(35.6011)
  isActive  Boolean    @default(true)
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  businesses Business[]
  events     Event[]
  offers     Offer[]
  projects   Project[]
  orders     Order[]
  lostFound     LostFoundItem[]
  announcements Announcement[]
  deliveries    DeliveryRequest[]
}

// A business category (Coffee Shops, Restaurants, ...). Global across cities,
// fully editable from the admin panel.
model Category {
  id         Int        @id @default(autoincrement())
  slug       String     @unique
  name       String
  group      String     @default("More") // parent group, e.g. "Food & Drinks"
  icon       String     @default("🏷️") // emoji or icon key
  color      String     @default("#0ea5a4")
  sortOrder  Int        @default(0)
  isActive   Boolean    @default(true)
  commissionRate Float   @default(0) // platform % for this category (0 = use global default)
  businesses Business[]
}

// A business listing. One profile page per business, scoped to a city.
model Business {
  id          Int      @id @default(autoincrement())
  slug        String   @unique // global unique slug -> /aley/<slug>
  cityId      Int
  city        City     @relation(fields: [cityId], references: [id])
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])

  name        String
  tagline     String   @default("")
  description String   @default("")
  logo        String?
  cover       String?
  gallery     String   @default("[]") // JSON string[] of image URLs

  // Contact & socials
  phone     String   @default("")
  whatsapp  String   @default("")
  instagram String   @default("")
  facebook  String   @default("")
  website   String   @default("")
  email     String   @default("")

  // Location
  address String  @default("")
  lat     Float?
  lng     Float?

  // Hours: JSON [{day:0-6, open:"09:00", close:"22:00", closed:false}]
  hours String @default("[]")

  // Attributes used by filters
  priceRange      Int     @default(2) // 1-4 ($ to $$$$)
  hasDelivery     Boolean @default(false)
  hasReservations Boolean @default(false)
  // Appointment booking (salons, clinics, mechanics…). Admin toggles per business.
  hasBooking      Boolean @default(false)
  // JSON: { workingHours:[{day,open,close,closed}], breaks:[{day,start,end}], daysOff:["YYYY-MM-DD"], slotInterval, capacity, leadTimeHours, horizonDays }
  bookingConfig   String  @default("{}")

  // Rich content (JSON strings)
  tags     String @default("[]") // string[] of services/keywords (amenities)
  faqs     String @default("[]") // [{q,a}]
  products String @default("[]") // [{title, items:[{name, price?, description?}]}] — menus/collections/rooms/services
  ownerName String @default("") // display-only owner/manager name

  productLabel String @default("Products & Services") // section heading on the profile

  // Curation & trust
  isPublished Boolean @default(true)
  isFeatured  Boolean @default(false)
  isVerified  Boolean @default(false)
  isClaimed   Boolean @default(false)
  // Owner-submitted listings wait for admin approval before going public.
  // APPROVED (default for seeded/admin-created) | PENDING | REJECTED
  reviewStatus String @default("APPROVED")

  // Cached review aggregates (kept in sync when a review is approved)
  rating      Float @default(0)
  reviewCount Int   @default(0)
  viewCount   Int   @default(0)

  commissionRate Float @default(10) // platform commission % charged to this business

  ownerId   Int?
  owner     Owner?   @relation(fields: [ownerId], references: [id])
  createdAt DateTime @default(now())

  reviews        Review[]
  events         Event[]
  offers         Offer[]
  favorites      Favorite[]
  businessOrders BusinessOrder[]
  claims         BusinessClaim[]
  reservations   Reservation[]
  services       Service[]
  staff          StaffMember[]
  appointments   Appointment[]
  customerProfiles CustomerProfile[]
  waitlist       Waitlist[]
  facilities     Facility[]
  facilityBookings FacilityBooking[]
  voucherTypes   VoucherType[]
  vouchers       Voucher[]
  transactions   Transaction[]
  payouts        Payout[]
  analyticsEvents AnalyticsEvent[]
  announcements  BusinessAnnouncement[]
  // Spare-parts shop profile (JSON: {brands:[], makes:[], partCategories:[], newParts, usedParts, oem, aftermarket})
  partsProfile   String @default("{}")
  serviceQuotes  ServiceQuote[]
  serviceTargets ServiceRequestTarget[]
  collectionItems CollectionItem[]
}

// A business owner account (manages one or more businesses from a dashboard).
model Owner {
  id           Int        @id @default(autoincrement())
  name         String
  email        String     @unique
  passwordHash String
  phone        String     @default("")
  createdAt    DateTime   @default(now())
  businesses   Business[]
  claims       BusinessClaim[]
}

// An owner's request to take ownership of an existing (unclaimed) listing.
// Admin reviews and approves → the business is assigned to that owner.
model BusinessClaim {
  id         Int      @id @default(autoincrement())
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  ownerId    Int
  owner      Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  message    String   @default("")
  status     String   @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt  DateTime @default(now())
}

// Admin alerts (new business submitted, claim requested, etc.). Shown in the
// admin panel and, when SMTP is configured, mirrored to the admin's email.
model Notification {
  id        Int      @id @default(autoincrement())
  kind      String // BUSINESS_SUBMITTED | BUSINESS_CLAIM
  title     String
  body      String   @default("")
  link      String   @default("") // admin path to act on it
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// A platform visitor account (favourites, reviews, follows).
model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String?  @unique
  phone        String?  @unique
  passwordHash String?
  googleId     String?  @unique
  appleId      String?  @unique
  avatar       String?
  createdAt    DateTime @default(now())
  reviews      Review[]
  favorites    Favorite[]
  reservations Reservation[]
  appointments Appointment[]
  facilityBookings FacilityBooking[]
  purchasedVouchers Voucher[] @relation("purchasedVouchers")
  walletEntries WalletEntry[]
  savedOffers   OfferSave[]
  offerClaims   OfferRedemption[]
  savedEvents   EventSave[]
  eventRsvps    EventRSVP[]
  eventBookings EventBooking[]
  serviceRequests ServiceRequest[]
  savedCollections CollectionSave[]
  vehicles      UserVehicle[]
  savedGiftCards VoucherSave[]
  purchasedPlatformCards PlatformGiftCard[] @relation("purchasedPlatformCards")
  redeemedPlatformCards  PlatformGiftCard[] @relation("redeemedPlatformCards")
}

// A customer's saved vehicle ("garage") so they can reuse car details in requests.
model UserVehicle {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String   @default("")
  make      String   @default("")
  model     String   @default("")
  year      String   @default("")
  engine    String   @default("")
  vin       String   @default("")
  plate     String   @default("")
  createdAt DateTime @default(now())
  @@index([userId])
}

// ---- Discover: curated collections of places ----
// Admin-managed themed collections ("Worth the Drive", "Local Favorites"…).
// Each has a cover, description, and a hand-picked, ordered set of businesses.
model Collection {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  description String   @default("")
  emoji       String   @default("✨")
  coverImage  String?
  cityId      Int?     // optional: a collection can be city-specific
  isFeatured  Boolean  @default(false) // shown on the homepage Discover strip
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  items       CollectionItem[]
  saves       CollectionSave[]
}

model CollectionItem {
  id           Int      @id @default(autoincrement())
  collectionId Int
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  businessId   Int
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sortOrder    Int      @default(0)
  @@unique([collectionId, businessId])
  @@index([collectionId])
}

model CollectionSave {
  id           Int      @id @default(autoincrement())
  collectionId Int
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  @@unique([collectionId, userId])
  @@index([userId])
}

// ---- Generic request-for-quote (RFQ) system ----
// A customer posts ONE request; it broadcasts to matching businesses, who reply
// with quotes. Built generic (type) so it extends to mechanics/plumbers/etc.
// `payload` holds the type-specific fields (e.g. car make/model/year for parts).
model ServiceRequest {
  id            Int      @id @default(autoincrement())
  type          String   @default("SPARE_PARTS") // SPARE_PARTS | MECHANIC | PLUMBER | …
  categorySlug  String   @default("") // target category (e.g. "auto-parts")
  cityId        Int?
  userId        Int?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName  String   @default("")
  customerPhone String   @default("")
  customerWhatsapp String @default("")
  city          String   @default("")
  payload       String   @default("{}") // JSON, type-specific (make/model/year/part…)
  notes         String   @default("")
  photos        String   @default("[]") // JSON array of image URLs
  budget        Float    @default(0)
  // SUBMITTED | SENT | REPLIES | SELECTED | COMPLETED | CANCELLED | EXPIRED
  status        String   @default("SENT")
  selectedQuoteId Int?
  createdAt     DateTime @default(now())
  expiresAt     DateTime?
  quotes        ServiceQuote[]
  targets       ServiceRequestTarget[]
  @@index([type])
  @@index([userId])
}

// Which businesses a request was broadcast to (their per-shop read/reply state).
model ServiceRequestTarget {
  id         Int      @id @default(autoincrement())
  requestId  Int
  request    ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  status     String   @default("NEW") // NEW | VIEWED | REPLIED | DECLINED
  createdAt  DateTime @default(now())
  @@unique([requestId, businessId])
  @@index([businessId])
}

// A shop's reply to a request (price + availability).
model ServiceQuote {
  id            Int      @id @default(autoincrement())
  requestId     Int
  request       ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  businessId    Int
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  available     Boolean  @default(true)
  price         Float    @default(0)
  eta           String   @default("") // estimated completion time, e.g. "2-3 days"
  offersDelivery Boolean @default(false) // delivery / on-site / mobile service
  note          String   @default("")
  photos        String   @default("[]") // JSON array of image URLs
  status        String   @default("SENT") // SENT | ACCEPTED | DECLINED
  createdAt     DateTime @default(now())
  @@unique([requestId, businessId])
  @@index([requestId])
  @@index([businessId])
}

// Customer prepaid wallet ledger: one row per money event. The balance is
// COMPUTED from these rows (sum of COMPLETED entries) — never a stored, drifting
// number — mirroring the business-side Transaction ledger. Gateway-agnostic:
// top-ups record now and a real payment provider can plug in later.
model WalletEntry {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // TOPUP | SPEND | REFUND | ADJUSTMENT | BONUS
  amount      Float    @default(0) // signed: + credit (top-up/refund/bonus), − debit (spend)
  status      String   @default("COMPLETED") // COMPLETED | PENDING | FAILED
  method      String   @default("CARD") // how it was loaded: CARD | WHISH | CASH | MANUAL
  source      String   @default("") // ORDER | VOUCHER | FACILITY | APPOINTMENT | TOPUP | REFUND | ADJUSTMENT
  refId       Int      @default(0) // id of the related order/voucher/booking/transaction
  code        String   @default("") // order number / voucher code / reference
  description String   @default("")
  createdBy   String   @default("") // admin who made a manual adjustment
  createdAt   DateTime @default(now())
  @@index([userId])
}

// A table/booking request a visitor makes to a business. The owner confirms or
// declines it from their dashboard.
model Reservation {
  id         Int      @id @default(autoincrement())
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId     Int?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name       String
  phone      String
  email      String   @default("")
  partySize  Int      @default(2)
  date       String // "2026-07-01"
  time       String // "20:00"
  note       String   @default("")
  status     String   @default("PENDING") // PENDING | CONFIRMED | DECLINED | CANCELLED
  createdAt  DateTime @default(now())
}

// A bookable service offered by a business (haircut, consultation, oil change…).
model Service {
  id          Int      @id @default(autoincrement())
  businessId  Int
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  description String   @default("")
  durationMin Int      @default(30) // appointment length in minutes
  price       Float    @default(0)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  appointments Appointment[]
}

// A staff member customers can optionally book with.
model StaffMember {
  id         Int      @id @default(autoincrement())
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  role       String   @default("")
  avatar     String?
  bio        String   @default("")
  experience String   @default("") // e.g. "5 years"
  languages  String   @default("[]") // JSON string[] of spoken languages
  rating     Float    @default(0)
  // JSON: { workingHours:[{day,open,close,closed}], breaks:[{day,start,end}], timeOff:[{from,to}], daysOff:[date] }
  schedule   String   @default("{}")
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  appointments Appointment[]
}

// Lightweight per-business CRM record keyed by phone: owner-set tag + notes.
// Visit/spend stats are computed from appointments, not stored here.
model CustomerProfile {
  id         Int      @id @default(autoincrement())
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  phone      String
  name       String   @default("")
  tag        String   @default("") // "" | VIP | REGULAR | FIRST_VISIT
  notes      String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@unique([businessId, phone])
}

// A customer appointment with a business (and optionally a service + staff member).
model Appointment {
  id           Int      @id @default(autoincrement())
  businessId   Int
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  serviceId    Int?
  service      Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  staffId      Int?
  staff        StaffMember? @relation(fields: [staffId], references: [id], onDelete: SetNull)
  userId       Int?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName String
  customerPhone String
  note         String   @default("")
  date         String // "2026-07-01"
  time         String // "14:30" (start)
  durationMin  Int      @default(30) // snapshot of service duration
  price        Float    @default(0) // snapshot
  serviceName  String   @default("") // snapshot for display/history
  staffName    String   @default("")
  // PENDING | CONFIRMED | RESCHEDULED | CANCELLED | COMPLETED | NO_SHOW
  status       String   @default("PENDING")
  checkInCode  String   @default("") // short code encoded in the customer's QR
  arrivedAt    DateTime? // set when the business scans/marks the customer as arrived
  createdAt    DateTime @default(now())

  @@index([businessId, date])
}

// The financial ledger: one row per money event across all channels. Each row
// carries gross, platform commission, delivery fee, and net owed to the business,
// plus payment + payout + refund status. Gateway-agnostic (records now; a real
// provider just flips paymentStatus and supplies refs later).
model Transaction {
  id             Int      @id @default(autoincrement())
  businessId     Int?
  business       Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  // VOUCHER | FACILITY | ORDER | APPOINTMENT | DELIVERY | EVENT | ADJUSTMENT
  source         String
  refId          Int      @default(0) // id of the underlying record
  code           String   @default("") // voucher code / order number / reference
  description    String   @default("")
  customerName   String   @default("")
  customerPhone  String   @default("")
  userId         Int?
  amount         Float    @default(0) // gross paid by the customer
  commission     Float    @default(0) // platform commission
  deliveryFee    Float    @default(0) // platform delivery fee (if any)
  net            Float    @default(0) // amount owed to the business (gross - commission)
  refundedAmount Float    @default(0)
  // UNPAID | PENDING | PAID | FAILED | REFUNDED | PARTIALLY_REFUNDED | CANCELLED
  status         String   @default("PAID")
  method         String   @default("CARD") // CASH | PAY_AT_BUSINESS | MANUAL | PENDING_ONLINE | CARD | WHISH …
  // UNPAID | IN_PAYOUT | PAID  (business payout state of the net)
  payoutStatus   String   @default("UNPAID")
  payoutId       Int?
  payout         Payout?  @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  notes          String   @default("")
  confirmedBy    String   @default("") // admin who created/edited/confirmed it
  createdAt      DateTime @default(now())
  refundedAt     DateTime?
  @@index([businessId])
  @@index([source])
  @@index([payoutId])
}

// A batch payout to a business for a period: sums net owed, minus refunds, plus
// adjustments → final amount. Admin creates these manually for now.
model Payout {
  id          Int      @id @default(autoincrement())
  businessId  Int
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  periodStart String   @default("")
  periodEnd   String   @default("")
  grossSales  Float    @default(0)
  commission  Float    @default(0)
  refunds     Float    @default(0)
  adjustments Float    @default(0)
  net         Float    @default(0) // final payout amount
  status      String   @default("PENDING") // PENDING | PAID | FAILED | CANCELLED
  method      String   @default("MANUAL")
  notes       String   @default("")
  createdBy   String   @default("")
  createdAt   DateTime @default(now())
  paidAt      DateTime?
  transactions Transaction[]
}

// A gift-voucher product a business sells (template).
model VoucherType {
  id          Int      @id @default(autoincrement())
  businessId  Int
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  kind        String   @default("FIXED") // FIXED | PRODUCT | SERVICE
  name        String
  description String   @default("")
  image       String?
  value       Float    @default(0) // face value (FIXED) / implied value
  price       Float    @default(0) // what the buyer pays (can be < value for promos)
  expiryDays  Int      @default(0) // 0 = no expiry
  maxQuantity Int      @default(0) // 0 = unlimited
  soldCount   Int      @default(0)
  terms       String   @default("")
  status      String   @default("ACTIVE") // ACTIVE | PAUSED
  isFeatured  Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  vouchers    Voucher[]
  saves       VoucherSave[]
}

// A customer bookmarking a gift-card product.
model VoucherSave {
  id            Int      @id @default(autoincrement())
  voucherTypeId Int
  voucherType   VoucherType @relation(fields: [voucherTypeId], references: [id], onDelete: Cascade)
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  @@unique([voucherTypeId, userId])
  @@index([userId])
}

// An issued/purchased gift voucher.
model Voucher {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  businessId     Int
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  voucherTypeId  Int?
  voucherType    VoucherType? @relation(fields: [voucherTypeId], references: [id], onDelete: SetNull)
  kind           String   @default("FIXED")
  title          String   @default("") // snapshot of the voucher name
  value          Float    @default(0) // face value
  balance        Float    @default(0) // remaining value (FIXED); product/service redeem in one shot
  price          Float    @default(0) // amount paid
  purchaserUserId Int?
  purchaser      User?    @relation("purchasedVouchers", fields: [purchaserUserId], references: [id], onDelete: SetNull)
  purchaserName  String   @default("")
  purchaserEmail String   @default("")
  recipientName  String   @default("")
  recipientEmail String   @default("")
  recipientPhone String   @default("")
  message        String   @default("")
  deliverAt      DateTime? // scheduled gift delivery; null = immediate
  // PENDING_DELIVERY | ACTIVE | REDEEMED | EXPIRED | DISABLED
  status         String   @default("ACTIVE")
  expiresAt      DateTime?
  paymentMethod  String   @default("CARD")
  redeemedAt     DateTime?
  createdAt      DateTime @default(now())
  redemptions    VoucherRedemption[]
  @@index([businessId])
}

// A single redemption against a voucher (audit + partial balance tracking).
model VoucherRedemption {
  id        Int      @id @default(autoincrement())
  voucherId Int
  voucher   Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  amount    Float    @default(0)
  note      String   @default("")
  createdAt DateTime @default(now())
}

// A Platform Gift Card design (admin-managed): a visual theme + the value limits
// buyers can pick within it. Unlike a business voucher, a platform gift card is
// redeemable anywhere on the platform — the recipient redeems it into their wallet
// and spends the credit at any participating business.
model PlatformCardDesign {
  id        Int      @id @default(autoincrement())
  name      String                                  // "Birthday", "Classic"…
  occasion  String   @default("GENERAL")            // GENERAL | BIRTHDAY | HOLIDAY | WEDDING | GRADUATION | ANNIVERSARY | THANK_YOU | CONGRATS
  emoji     String   @default("🎁")
  gradient  String   @default("from-brand to-brand-dark") // tailwind gradient classes for the card art
  image     String?                                 // optional background image
  minValue  Float    @default(10)
  maxValue  Float    @default(1000)
  presets   String   @default("[25,50,100,250]")    // JSON number[] of quick amounts
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  cards     PlatformGiftCard[]
}

// An issued Platform Gift Card. On redemption the amount is credited to the
// recipient's wallet (a "GIFT" ledger entry) and the card is marked REDEEMED.
model PlatformGiftCard {
  id               Int      @id @default(autoincrement())
  code             String   @unique
  designId         Int?
  design           PlatformCardDesign? @relation(fields: [designId], references: [id], onDelete: SetNull)
  occasion         String   @default("GENERAL")     // snapshot of the design at purchase time
  emoji            String   @default("🎁")           // snapshot
  gradient         String   @default("from-brand to-brand-dark") // snapshot
  amount           Float    @default(0)              // face value purchased
  balance          Float    @default(0)              // un-redeemed value (== amount until redeemed, then 0)
  // PENDING_DELIVERY | ACTIVE | REDEEMED | DISABLED | REFUNDED
  status           String   @default("ACTIVE")
  purchaserUserId  Int?
  purchaser        User?    @relation("purchasedPlatformCards", fields: [purchaserUserId], references: [id], onDelete: SetNull)
  purchaserName    String   @default("")
  purchaserEmail   String   @default("")
  recipientName    String   @default("")
  recipientEmail   String   @default("")
  recipientPhone   String   @default("")
  message          String   @default("")
  deliverAt        DateTime?                         // scheduled gift delivery; null = immediate
  paymentMethod    String   @default("CARD")         // CARD | WALLET
  redeemedByUserId Int?
  redeemer         User?    @relation("redeemedPlatformCards", fields: [redeemedByUserId], references: [id], onDelete: SetNull)
  redeemedAt       DateTime?
  expiresAt        DateTime?
  createdAt        DateTime @default(now())
  @@index([status])
}

// A rentable facility/court/field/room a business books by the hour.
model Facility {
  id           Int      @id @default(autoincrement())
  businessId   Int
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name         String // "Court 1", "Field A", "Main Hall"
  type         String   @default("") // "Padel court", "Football field", "Event hall"
  description  String   @default("")
  image        String?
  hourlyRate   Float    @default(0)
  capacityNote String   @default("") // "Up to 4 players", "Seats 200"
  // JSON: { weekendRate, peakRate, peakStart, peakEnd, nightRate, nightStart, holidayRate, holidays:[date],
  //         minHours, maxHours, slotIncrementMin }
  pricing      String   @default("{}")
  // JSON: { workingHours:[{day,open,close,closed}], blockedDates:[date], maintenance:[{from,to,reason}] }
  schedule     String   @default("{}")
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  bookings     FacilityBooking[]
}

// An hourly booking of a facility.
model FacilityBooking {
  id            Int      @id @default(autoincrement())
  businessId    Int
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  facilityId    Int
  facility      Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  userId        Int?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName  String
  customerPhone String
  date          String // "2026-07-01"
  startTime     String // "18:00"
  durationMin   Int      @default(60)
  players       Int      @default(0)
  note          String   @default("")
  price         Float    @default(0)
  facilityName  String   @default("") // snapshot
  // CONFIRMED | PENDING | CANCELLED | COMPLETED | NO_SHOW
  status        String   @default("CONFIRMED")
  checkInCode   String   @default("")
  arrivedAt     DateTime?
  createdAt     DateTime @default(now())

  @@index([businessId, date])
  @@index([facilityId, date])
}

// A customer waiting for a slot to open on a fully-booked day.
model Waitlist {
  id            Int      @id @default(autoincrement())
  businessId    Int
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  serviceId     Int?
  staffId       Int?
  userId        Int?
  customerName  String
  customerPhone String
  date          String   // desired date "YYYY-MM-DD"
  note          String   @default("")
  status        String   @default("WAITING") // WAITING | NOTIFIED | CONVERTED | CLOSED
  createdAt     DateTime @default(now())

  @@index([businessId, date])
}

model Favorite {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, businessId])
}

// A rating + review for a business. Moderated before it shows publicly.
model Review {
  id         Int      @id @default(autoincrement())
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId     Int?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  authorName String
  rating     Int // 1-5
  comment    String   @default("")
  reply      String? // business owner's response
  repliedAt  DateTime?
  status     String   @default("PENDING") // PENDING | APPROVED | REJECTED
  featured   Boolean  @default(false) // owner-highlighted review (shown first on the public page)
  reported   Boolean  @default(false) // owner flagged as inappropriate; admin reviews
  reportReason String @default("")
  createdAt  DateTime @default(now())
}

// A business's own announcement / promotion post shown on its public page
// (e.g. "Open late this Ramadan", "New summer menu", "20% off this weekend").
model BusinessAnnouncement {
  id         Int      @id @default(autoincrement())
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title      String
  body       String   @default("")
  image      String?
  pinned     Boolean  @default(false)
  isActive   Boolean  @default(true)
  startsAt   DateTime?
  endsAt     DateTime?
  createdAt  DateTime @default(now())
  @@index([businessId])
}

// An event published by a business or the city.
model Event {
  id          Int      @id @default(autoincrement())
  cityId      Int
  city        City     @relation(fields: [cityId], references: [id])
  businessId  Int?
  business    Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  title       String
  description String   @default("")
  category    String   @default("") // taxonomy in lib/events.ts EVENT_CATEGORIES
  image       String?
  gallery     String   @default("[]") // JSON array of {url, caption?}
  location    String   @default("") // venue / address text
  lat         Float?
  lng         Float?
  organizerName  String @default("")
  organizerPhone String @default("")
  organizerEmail String @default("")
  startTime   DateTime
  endTime     DateTime?
  capacity    Int      @default(0) // total attendee cap (0 = unlimited)
  isFeatured  Boolean  @default(false)
  isPublished Boolean  @default(true)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  ticketTypes EventTicketType[]
  bookings    EventBooking[]
  rsvps       EventRSVP[]
  saves       EventSave[]
}

// A ticket tier for an event. A free event has none (or a FREE tier); paid events
// can offer GENERAL / VIP / EARLY_BIRD / STUDENT / FAMILY tiers.
model EventTicketType {
  id          Int      @id @default(autoincrement())
  eventId     Int
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name        String
  kind        String   @default("GENERAL") // GENERAL | VIP | EARLY_BIRD | STUDENT | FAMILY | FREE
  price       Float    @default(0)
  quantity    Int      @default(0) // 0 = unlimited
  soldCount   Int      @default(0)
  description String   @default("")
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  bookings    EventBooking[]
  @@index([eventId])
}

// A ticket reservation/purchase (free reserve or paid). Code/QR shown at the door.
model EventBooking {
  id            Int      @id @default(autoincrement())
  eventId       Int
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketTypeId  Int?
  ticketType    EventTicketType? @relation(fields: [ticketTypeId], references: [id], onDelete: SetNull)
  businessId    Int?
  userId        Int?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName  String   @default("")
  customerPhone String   @default("")
  customerEmail String   @default("")
  quantity      Int      @default(1)
  amount        Float    @default(0) // total paid
  method        String   @default("FREE") // FREE | WALLET | CARD | PAY_AT_VENUE
  status        String   @default("CONFIRMED") // CONFIRMED | CANCELLED | CHECKED_IN
  code          String   @unique
  checkedInAt   DateTime?
  createdAt     DateTime @default(now())
  @@index([eventId])
  @@index([userId])
}

// Going / Interested / Maybe.
model EventRSVP {
  id        Int      @id @default(autoincrement())
  eventId   Int
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("INTERESTED") // INTERESTED | GOING | MAYBE
  createdAt DateTime @default(now())
  @@unique([eventId, userId])
  @@index([eventId])
}

// Bookmarked event.
model EventSave {
  id        Int      @id @default(autoincrement())
  eventId   Int
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([eventId, userId])
  @@index([userId])
}

// A promotion / discount published by a business.
model Offer {
  id          Int      @id @default(autoincrement())
  cityId      Int
  city        City     @relation(fields: [cityId], references: [id])
  businessId  Int
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title       String
  description String   @default("")
  // PERCENT | BOGO | FREE_ITEM | HAPPY_HOUR | PACKAGE | STUDENT | BIRTHDAY | SEASONAL | FIRST_VISIT | LOYALTY | DISCOUNT(legacy)
  type        String   @default("PERCENT")
  badge       String   @default("") // big promo label, e.g. "50% OFF", "Buy 1 Get 1", "Free Dessert"
  terms       String   @default("") // terms & conditions
  redeemInfo  String   @default("") // how to redeem (shown to the customer)
  image       String?
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  maxRedemptions Int   @default(0) // 0 = unlimited
  redeemedCount  Int   @default(0)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  saves       OfferSave[]
  redemptions OfferRedemption[]
}

// A customer bookmarking an offer ("save deal").
model OfferSave {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  offerId   Int
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, offerId])
  @@index([userId])
}

// A customer claiming/redeeming an offer at a business. Claim → unique code/QR the
// staff scans; owner marks it REDEEMED (mirrors the gift-voucher redemption flow).
model OfferRedemption {
  id            Int      @id @default(autoincrement())
  offerId       Int
  offer         Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  businessId    Int
  userId        Int?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  code          String   @unique
  status        String   @default("CLAIMED") // CLAIMED | REDEEMED | EXPIRED | CANCELLED
  customerName  String   @default("")
  customerPhone String   @default("")
  createdAt     DateTime @default(now())
  redeemedAt    DateTime?
  @@index([offerId])
  @@index([userId])
  @@index([businessId])
}

// Key/value store for homepage content, ads, feature flags, etc.
model Setting {
  key   String @id
  value String
}

// ---------------------------------------------------------------------------
// Community Projects — civic crowdfunding for the city (GoFundMe-style, local).
// ---------------------------------------------------------------------------
model Project {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  cityId      Int
  city        City     @relation(fields: [cityId], references: [id])
  title       String
  description String   @default("")
  type        String   @default("") // Street, Trees, Lighting, Benches, Cleanup...
  location    String   @default("")
  lat         Float?
  lng         Float?

  // Image sets (JSON string[] of URLs)
  beforePhotos   String @default("[]")
  proposedPhotos String @default("[]")
  progressPhotos String @default("[]")

  // Timeline / milestones: JSON [{ label, date, done }]
  timeline String @default("[]")

  manager  String @default("") // who is managing the project (transparency)
  fundingGoal Float @default(0)
  amountRaised Float @default(0) // cached sum of donations
  contributorCount Int @default(0) // cached count of donations
  voteCount Int @default(0) // cached count of votes

  // PROPOSED | FUNDING | APPROVED | IN_PROGRESS | COMPLETED | PAUSED
  status     String  @default("PROPOSED")
  isFeatured Boolean @default(false)
  isPublished Boolean @default(true) // user suggestions can be hidden until approved

  finalCost       Float?
  completedReport String @default("")
  submittedBy     String @default("") // suggester display name
  submittedByUserId Int?
  createdAt DateTime @default(now())

  donations Donation[]
  expenses  Expense[]
  updates   ProjectUpdate[]
  comments  ProjectComment[]
  votes     ProjectVote[]
  follows   ProjectFollow[]
}

model Donation {
  id        Int      @id @default(autoincrement())
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    Int? // visitor account, if logged in
  donorName String
  amount    Float
  anonymous Boolean  @default(false)
  message   String   @default("")
  createdAt DateTime @default(now())
}

model Expense {
  id         Int      @id @default(autoincrement())
  projectId  Int
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label      String
  amount     Float
  receipt    String? // uploaded receipt image URL
  contractor String   @default("") // contractor / quotation note
  createdAt  DateTime @default(now())
}

model ProjectUpdate {
  id        Int      @id @default(autoincrement())
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  body      String   @default("")
  images    String   @default("[]") // JSON string[]
  createdAt DateTime @default(now())
}

model ProjectComment {
  id         Int      @id @default(autoincrement())
  projectId  Int
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId     Int?
  authorName String
  body       String
  createdAt  DateTime @default(now())
}

model ProjectVote {
  id        Int      @id @default(autoincrement())
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    Int
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

model ProjectFollow {
  id        Int      @id @default(autoincrement())
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    Int
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

// ---------------------------------------------------------------------------
// Marketplace ordering — one customer checkout can span multiple businesses.
// An Order is the combined checkout; each BusinessOrder is one business's
// "ticket" with its own status/prep time/commission; OrderItems are the lines.
// ---------------------------------------------------------------------------
model Order {
  id            Int      @id @default(autoincrement())
  number        String   @unique
  cityId        Int
  city          City     @relation(fields: [cityId], references: [id])
  customerId    Int? // visitor account, if logged in
  customerName  String
  customerPhone String
  customerEmail String   @default("")
  fulfillment   String   @default("DELIVERY") // DELIVERY | PICKUP
  address       String   @default("")
  lat           Float?
  lng           Float?
  note          String   @default("")

  itemsSubtotal   Float @default(0)
  deliveryFee     Float @default(0)
  total           Float @default(0)
  commissionTotal Float @default(0)

  paymentMethod String @default("CASH") // CASH | ONLINE
  paid          Boolean @default(false)

  // Delivery / driver progress across the whole order.
  deliveryStatus String @default("PENDING") // PENDING | COLLECTING | OUT_FOR_DELIVERY | DELIVERED | CANCELLED
  driverId       Int? // delivery driver who accepted/was assigned this order
  driver         Driver? @relation(fields: [driverId], references: [id], onDelete: SetNull)
  driverName     String @default("")
  status         String @default("PLACED") // PLACED | COMPLETED | CANCELLED

  createdAt      DateTime @default(now())
  businessOrders BusinessOrder[]
}

model BusinessOrder {
  id         Int      @id @default(autoincrement())
  orderId    Int
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  businessId Int
  business   Business @relation(fields: [businessId], references: [id])

  status   String @default("PENDING") // PENDING | PREPARING | READY | CANCELLED
  prepTime String @default("")

  subtotal         Float @default(0)
  commissionRate   Float @default(0) // snapshot of the business's rate at order time
  commissionAmount Float @default(0)

  createdAt DateTime    @default(now())
  items     OrderItem[]
}

model OrderItem {
  id              Int           @id @default(autoincrement())
  businessOrderId Int
  businessOrder   BusinessOrder @relation(fields: [businessOrderId], references: [id], onDelete: Cascade)
  name            String
  price           Float
  quantity        Int
  lineTotal       Float
}

// ---------------------------------------------------------------------------
// Community board — Lost & Found posts + official Public Notices.
// ---------------------------------------------------------------------------

// A resident's "I lost…" / "I found…" post. Goes live immediately; admins can
// hide abuse or mark it resolved once the item is reunited with its owner.
model LostFoundItem {
  id           Int      @id @default(autoincrement())
  cityId       Int
  city         City     @relation(fields: [cityId], references: [id])
  userId       Int? // poster's visitor account, if logged in
  type         String   @default("LOST") // LOST | FOUND
  title        String
  description  String   @default("")
  category     String   @default("Other") // Phone, Keys, Wallet, Pet, Document, Jewelry, Bag, Other
  location     String   @default("") // where it was lost / found
  date         String   @default("") // "2026-06-26" (when), free-form string like Reservation
  image        String?
  contactName  String
  contactPhone String   @default("")
  contactEmail String   @default("")
  status       String   @default("OPEN") // OPEN | RESOLVED
  isPublished  Boolean  @default(true) // admin can hide
  createdAt    DateTime @default(now())
}

// An official notice / announcement, published by the city/admin (municipality
// updates, water/electricity, road works, emergencies, weather…). Read-only for
// the public.
model Announcement {
  id          Int       @id @default(autoincrement())
  cityId      Int
  city        City      @relation(fields: [cityId], references: [id])
  title       String
  body        String    @default("")
  // GENERAL | MUNICIPALITY | UTILITY | EMERGENCY | EVENT | ROADS | WEATHER | HEALTH
  category    String    @default("GENERAL")
  image       String?
  link        String    @default("") // optional external link / source
  isPinned    Boolean   @default(false)
  isPublished Boolean   @default(true)
  publishedAt DateTime  @default(now())
  expiresAt   DateTime? // hidden automatically after this time
  createdAt   DateTime  @default(now())
}

// ---------------------------------------------------------------------------
// Delivery service — a general courier / pickup-and-drop-off service. Works for
// listed shops AND for any manual address ("pick up from a shop in Beirut and
// deliver to Aley"). Separate from marketplace Orders. Price is an estimate the
// delivery team can finalise. Built to grow into online payment, driver
// accounts, live tracking, commissions, scheduling and multi-stop later.
// ---------------------------------------------------------------------------
model DeliveryRequest {
  id            Int      @id @default(autoincrement())
  number        String   @unique
  cityId        Int
  city          City     @relation(fields: [cityId], references: [id])
  customerId    Int? // visitor account, if logged in

  // ALEY_TO_ALEY | OUTSIDE_TO_ALEY | ALEY_TO_OUTSIDE | CUSTOM
  type          String   @default("ALEY_TO_ALEY")

  // Pickup (point A)
  pickupLabel   String
  pickupPhone   String   @default("") // optional phone of the pickup place (shop), so the driver can call
  pickupLat     Float?
  pickupLng     Float?
  pickupOutside Boolean  @default(false)

  // Drop-off (point B)
  dropoffLabel   String
  dropoffLat     Float?
  dropoffLng     Float?
  dropoffOutside Boolean @default(false)

  // What
  itemDescription String @default("")
  packageType     String @default("Parcel") // Document | Food | Parcel | Fragile | Groceries | Clothing | Electronics | Other
  packageSize     String @default("MEDIUM") // SMALL | MEDIUM | LARGE
  urgency         String @default("STANDARD") // STANDARD | EXPRESS
  preferredTime   String @default("")
  notes           String @default("")

  // Contact
  customerName  String
  customerPhone String

  businessId    Int? // linked listed shop, if the pickup is one (no FK — optional link)

  // Pricing (estimate now; team confirms finalPrice)
  distanceKm   Float  @default(0)
  estimatedMin Float  @default(0)
  estimatedMax Float  @default(0)
  finalPrice   Float?

  // Fulfilment
  // REQUESTED | ACCEPTED | HEADING_TO_PICKUP | PICKED_UP | ON_THE_WAY | DELIVERED | CANCELLED | REJECTED
  status      String   @default("REQUESTED")
  driverId    Int? // assigned/accepting driver
  driver      Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)
  driverName  String   @default("") // snapshot for quick display
  driverPhone String   @default("")
  driverNotes String   @default("") // notes the driver adds
  proofImage  String? // proof-of-delivery photo

  createdAt DateTime @default(now())
}

// Append-only interaction log powering the provider Analytics dashboard.
// One row per tracked interaction; everything (cards, charts, leaderboards,
// future conversion/ads/heatmap features) aggregates from here. Keep it lean.
model AnalyticsEvent {
  id         Int      @id @default(autoincrement())
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  // PROFILE_VIEW | SEARCH_APPEARANCE | PHONE_VIEW | CALL | WHATSAPP | WEBSITE | DIRECTIONS
  type       String
  meta       String   @default("") // future: referrer, search term, category, etc.
  createdAt  DateTime @default(now())

  @@index([businessId, type, createdAt])
  @@index([type, createdAt])
}

// A delivery driver account. Drivers log in to their own dashboard to claim and
// complete delivery requests. Admin-created accounts are ACTIVE; self-registered
// ones wait for approval (PENDING) and can be SUSPENDED.
model Driver {
  id           Int      @id @default(autoincrement())
  name         String
  email        String?  @unique
  phone        String   @unique
  passwordHash String
  vehicle      String   @default("") // e.g. "Motorbike", "Car · ABC-123"
  // 0 = use platform default; otherwise the platform's % commission on this driver.
  commissionRate Float  @default(0)
  status       String   @default("PENDING") // PENDING | ACTIVE | SUSPENDED
  createdAt    DateTime @default(now())
  deliveries   DeliveryRequest[]
  orders       Order[]
}
